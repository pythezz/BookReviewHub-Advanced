@model BookReviewHub.ViewModels.BookViewModel

<div class="card h-100 shadow-sm">
    <div class="card-body d-flex flex-column">
        <h5 class="card-title mb-1">
            <a asp-controller="Books" asp-action="Details" asp-route-id="@Model.Id"
               class="text-decoration-none text-dark stretched-link">
                @Model.Title
            </a>
        </h5>
        <p class="text-muted small mb-1">@Model.AuthorName</p>
        <span class="badge bg-secondary mb-2">@Model.GenreName</span>
        <div class="mt-auto d-flex justify-content-between align-items-center">
            <small class="text-muted">@Model.PublicationYear</small>
            <span>
                ★ @Model.AverageRating.ToString("0.0")
                <small class="text-muted">(@Model.ReviewCount)</small>
            </span>
        </div>
    </div>
</div>
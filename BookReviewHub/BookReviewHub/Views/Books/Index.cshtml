@model BookReviewHub.ViewModels.BookSearchViewModel
@{
    ViewData["Title"] = "Books";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Books</h1>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-primary">+ Add Book</a>
    }
</div>

<!-- Search & Filter -->
<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-2">
                <div class="col-md-5">
                    <input type="text" name="search" value="@Model.SearchTerm"
                           class="form-control" placeholder="Search by title or author…" />
                </div>
                <div class="col-md-3">
                    <select name="genreId" class="form-select" onchange="this.form.submit()">
                        <option value="">All Genres</option>
                        @foreach (var g in Model.Genres)
                        {
                            <option value="@g.Value"
                                    selected="@(g.Value == Model.GenreId?.ToString())">
                                @g.Text
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="sortBy" class="form-select" onchange="this.form.submit()">
                        <option value="" selected="@(Model.SortBy == null)">Sort: Title A–Z</option>
                        <option value="year_desc" selected="@(Model.SortBy == "year_desc")">Sort: Newest First</option>
                        <option value="year_asc" selected="@(Model.SortBy == "year_asc")">Sort: Oldest First</option>
                        <option value="rating" selected="@(Model.SortBy == "rating")">Sort: Top Rated</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-dark w-100">Go</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Books == null || !Model.Books.Any())
{
    <div class="text-center py-5 text-muted">
        <p class="fs-5">No books found.</p>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear Filters</a>
    </div>
}
else
{
    <p class="text-muted mb-3">
        Showing @Model.Books.Count of @Model.Books.TotalCount books
    </p>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var book in Model.Books)
        {
            <div class="col">
                @await Html.PartialAsync("_BookCard", book)
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.Books.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.Books.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-search="@Model.SearchTerm"
                       asp-route-genreId="@Model.GenreId"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-page="@(Model.CurrentPage - 1)">&laquo;</a>
                </li>
                @for (int i = 1; i <= Model.Books.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@Model.SearchTerm"
                           asp-route-genreId="@Model.GenreId"
                           asp-route-sortBy="@Model.SortBy"
                           asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.Books.HasNextPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-search="@Model.SearchTerm"
                       asp-route-genreId="@Model.GenreId"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-page="@(Model.CurrentPage + 1)">&raquo;</a>
                </li>
            </ul>
        </nav>
    }
}
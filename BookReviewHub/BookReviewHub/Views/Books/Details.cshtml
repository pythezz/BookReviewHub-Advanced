@model BookReviewHub.ViewModels.BookViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Title;
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var hasReviewed = ViewBag.HasReviewed as bool? ?? false;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Books" asp-action="Index">Books</a></li>
        <li class="breadcrumb-item active">@Model.Title</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h4">@Model.Title</h2>
                <p class="text-muted mb-1">by @Model.AuthorName</p>
                <span class="badge bg-secondary mb-3">@Model.GenreName</span>
                <dl class="mb-0">
                    <dt class="text-muted small">Publication Year</dt>
                    <dd>@Model.PublicationYear</dd>
                    <dt class="text-muted small">Average Rating</dt>
                    <dd>
                        @Model.AverageRating.ToString("0.0") / 5
                        <small class="text-muted">(@Model.ReviewCount reviews)</small>
                    </dd>
                </dl>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="mt-3">
                        @if (ViewBag.IsInList == true)
                        {
                            <form asp-controller="ReadingList" asp-action="Remove" method="post">
                                <input type="hidden" name="bookId" value="@Model.Id" />
                                <button class="btn btn-outline-danger btn-sm w-100">
                                    Remove from Reading List
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="ReadingList" asp-action="Add" method="post">
                                <input type="hidden" name="bookId" value="@Model.Id" />
                                <button class="btn btn-outline-primary btn-sm w-100">
                                    + Add to Reading List
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>
        <div class="mt-3 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
        </div>
    </div>

    <div class="col-lg-8">
        <h5>Description</h5>
        <p>@Model.Description</p>
        <hr />

        <h5 class="mb-3">Reviews <span class="badge bg-secondary">@Model.ReviewCount</span></h5>

        @if (User.Identity?.IsAuthenticated == true)
        {
            if (!hasReviewed)
            {
                <div class="card border-primary mb-4">
                    <div class="card-header bg-primary text-white">Write a Review</div>
                    <div class="card-body">
                        <form asp-controller="Reviews" asp-action="Create" method="post">
                            <input type="hidden" name="BookId" value="@Model.Id" />
                            <input type="hidden" name="BookTitle" value="@Model.Title" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Rating (1–5)</label>
                                <select name="Rating" class="form-select">
                                    <option value="5">5 – Excellent</option>
                                    <option value="4">4 – Good</option>
                                    <option value="3">3 – Average</option>
                                    <option value="2">2 – Poor</option>
                                    <option value="1">1 – Terrible</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Your Review</label>
                                <textarea name="Content" class="form-control" rows="4"
                                  placeholder="Share your thoughts…"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">Submit Review</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">You have already reviewed this book.</div>
            }
        }
        else
        {
            <div class="alert alert-secondary">
                <a asp-controller="Account" asp-action="Login">Log in</a> to write a review.
            </div>
        }

        @if (ViewBag.Reviews is IEnumerable<BookReviewHub.ViewModels.ReviewViewModel> reviews && reviews.Any())
        {
            @foreach (var review in reviews)
            {
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-1">
                            <strong>@review.UserDisplayName</strong>
                            <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </div>
                        <div class="mb-2">Rating: <strong>@review.Rating / 5</strong></div>
                        <p class="mb-1">@review.Content</p>
                        @if (userId == review.UserId || User.IsInRole("Administrator"))
                        {
                            <div class="mt-2 d-flex gap-2">
                                <a asp-controller="Reviews" asp-action="Edit"
                                   asp-route-id="@review.Id"
                                   class="btn btn-outline-secondary btn-sm">Edit</a>
                                <form asp-controller="Reviews" asp-action="Delete" method="post">
                                    <input type="hidden" name="id" value="@review.Id" />
                                    <input type="hidden" name="bookId" value="@review.BookId" />
                                    <button class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Delete this review?')">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted">No reviews yet. Be the first!</p>
        }
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
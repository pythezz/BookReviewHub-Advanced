@model IEnumerable<BookReviewHub.ViewModels.ReadingListItemViewModel>
@using BookReviewHub.Models
@{
    ViewData["Title"] = "My Reading List";
}

<h1 class="h3 mb-4">My Reading List</h1>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <p class="fs-5">Your reading list is empty.</p>
        <a asp-controller="Books" asp-action="Index" class="btn btn-primary mt-2">
            Browse Books
        </a>
    </div>
}
else
{
    var statusOrder = new[] { "WantToRead", "CurrentlyReading", "Read" };
    var statusLabels = new Dictionary<string, string>
    {
        ["WantToRead"] = "Want to Read",
        ["CurrentlyReading"] = "Currently Reading",
        ["Read"] = "Read"
    };

    @foreach (var status in statusOrder)
    {
        var group = Model.Where(x => x.Status == status).ToList();
        if (!group.Any()) continue;

        <h5 class="mt-4 mb-2 text-muted">
            @statusLabels[status]
            <span class="badge bg-secondary">@group.Count</span>
        </h5>

        <div class="list-group shadow-sm mb-3">
            @foreach (var item in group)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <a asp-controller="Books" asp-action="Details"
                               asp-route-id="@item.BookId" class="fw-semibold text-decoration-none">
                                @item.BookTitle
                            </a>
                            <small class="text-muted d-block">@item.AuthorName</small>
                            <small class="text-muted">Added @item.AddedAt.ToString("MMM dd, yyyy")</small>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            <form asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                                <input type="hidden" name="bookId" value="@item.BookId" />
                                <select name="status" class="form-select form-select-sm"
                                        onchange="this.form.submit()">
                                    @foreach (var s in Enum.GetValues<ReadingStatus>())
                                    {
                                        <option value="@s"
                                                selected="@(item.Status == s.ToString())">
                                            @statusLabels[s.ToString()]
                                        </option>
                                    }
                                </select>
                            </form>
                            <form asp-action="Remove" method="post">
                                <input type="hidden" name="bookId" value="@item.BookId" />
                                <button class="btn btn-outline-danger btn-sm"
                                        onclick="return confirm('Remove from list?')">
                                    Remove
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
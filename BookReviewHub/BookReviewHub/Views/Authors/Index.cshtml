@model IEnumerable<BookReviewHub.ViewModels.AuthorViewModel>
@{
    ViewData["Title"] = "Authors";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Authors</h1>
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Add Author</a>
    }
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var author in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">
                        <a asp-action="Details" asp-route-id="@author.Id"
                           class="text-decoration-none text-dark stretched-link">
                            @author.Name
                        </a>
                    </h5>
                    @if (!string.IsNullOrEmpty(author.Nationality))
                    {
                        <p class="text-muted small mb-1">@author.Nationality</p>
                    }
                    @if (author.BirthYear.HasValue)
                    {
                        <p class="text-muted small mb-1">b. @author.BirthYear</p>
                    }
                </div>
                <div class="card-footer text-muted small">
                    @author.BookCount book(s)
                </div>
            </div>
        </div>
    }
</div>
@model BookReviewHub.ViewModels.AuthorViewModel
@{
    ViewData["Title"] = "Delete Author";
}

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">Confirm Delete</h4>
            </div>
            <div class="card-body">
                <p class="fs-5">Delete author <strong>@Model.Name</strong>?</p>
                @if (Model.BookCount > 0)
                {
                    <div class="alert alert-warning">
                        This author has <strong>@Model.BookCount</strong> book(s).
                        Remove them before deleting.
                    </div>
                }
                <div class="d-flex gap-3 mt-3">
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                        <button class="btn btn-danger" @(Model.BookCount > 0 ? "disabled" : "")>
                            Delete
                        </button>
                    </form>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>
@model BookReviewHub.ViewModels.AuthorFormModel
@{
    ViewData["Title"] = "Edit Author";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h2 class="mb-4">Edit Author</h2>
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Nationality" class="form-label"></label>
                    <input asp-for="Nationality" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="BirthYear" class="form-label"></label>
                    <input asp-for="BirthYear" class="form-control" type="number" />
                    <span asp-validation-for="BirthYear" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Biography" class="form-label"></label>
                <textarea asp-for="Biography" class="form-control" rows="4"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
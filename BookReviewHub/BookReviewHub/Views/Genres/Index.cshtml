@model IEnumerable<BookReviewHub.ViewModels.GenreViewModel>
@{
    ViewData["Title"] = "Genres";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Genres</h1>
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Add Genre</a>
    }
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3">
    @foreach (var genre in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title mb-1">@genre.Name</h5>
                    <p class="text-muted small mt-auto mb-0">
                        @genre.BookCount book(s)
                    </p>
                </div>
                <div class="card-footer bg-transparent d-flex justify-content-between align-items-center py-2">
                    <a asp-action="Details" asp-route-id="@genre.Id"
                       class="btn btn-sm btn-outline-secondary">Details</a>
                    @if (User.IsInRole("Administrator"))
                    {
                        <div class="d-flex gap-1">
                            <a asp-action="Edit" asp-route-id="@genre.Id"
                               class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@genre.Id"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
@model IEnumerable<BookReviewHub.ViewModels.ReviewViewModel>
@{
    ViewData["Title"] = "My Reviews";
}

<h1 class="h3 mb-4">My Reviews</h1>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <p>You haven't written any reviews yet.</p>
        <a asp-controller="Books" asp-action="Index" class="btn btn-primary mt-2">Browse Books</a>
    </div>
}
else
{
    <div class="list-group shadow-sm">
        @foreach (var review in Model)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="mb-1">
                            <a asp-controller="Books" asp-action="Details"
                               asp-route-id="@review.BookId">@review.BookTitle</a>
                        </h6>
                        <div class="mb-1">Rating: <strong>@review.Rating / 5</strong></div>
                        <p class="mb-1 text-muted">@review.Content</p>
                        <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                    </div>
                    <div class="d-flex gap-2 ms-3">
                        <a asp-controller="Reviews" asp-action="Edit"
                           asp-route-id="@review.Id"
                           class="btn btn-outline-secondary btn-sm">Edit</a>
                        <form asp-controller="Reviews" asp-action="Delete" method="post">
                            <input type="hidden" name="id" value="@review.Id" />
                            <input type="hidden" name="bookId" value="@review.BookId" />
                            <button class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('Delete this review?')">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
@model IEnumerable<BookReviewHub.ViewModels.GenreViewModel>
@{
    ViewData["Title"] = "Manage Genres";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Manage Genres</h2>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Add Genre</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th class="text-center">Books</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var genre in Model)
                {
                    <tr>
                        <td class="fw-semibold">@genre.Name</td>
                        <td class="text-center">@genre.BookCount</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@genre.Id"
                               class="btn btn-outline-secondary btn-sm">Edit</a>
                            <form asp-action="Delete" asp-route-id="@genre.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this genre?')">
                                <button class="btn btn-outline-danger btn-sm"
                                        @(genre.BookCount > 0 ? "disabled" : "")>
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
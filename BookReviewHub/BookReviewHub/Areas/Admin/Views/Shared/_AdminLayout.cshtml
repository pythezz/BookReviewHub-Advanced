<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin – @ViewData["Title"] | BookReviewHub</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f4f6fb; }
        .admin-sidebar { min-height: calc(100vh - 56px); background: #212529; }
        .admin-sidebar .nav-link { color: #adb5bd; border-radius: 6px; }
        .admin-sidebar .nav-link:hover,
        .admin-sidebar .nav-link.active { color: #fff; background: #343a40; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-danger px-3" style="height:56px;">
        <span class="navbar-brand fw-bold">BookReviewHub Admin</span>
        <a asp-area="" asp-controller="Home" asp-action="Index"
           class="btn btn-outline-light btn-sm">
            Exit Admin
        </a>
    </nav>

    <div class="d-flex">
        <div class="admin-sidebar p-3" style="width:210px; min-width:210px;">
            <nav class="nav flex-column gap-1">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Books" ? "active" : "")"
                   asp-area="Admin" asp-controller="Books" asp-action="Index">Books</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Genres" ? "active" : "")"
                   asp-area="Admin" asp-controller="Genres" asp-action="Index">Genres</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                   asp-area="Admin" asp-controller="Users" asp-action="Index">Users</a>
            </nav>
        </div>

        <div class="flex-grow-1 p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
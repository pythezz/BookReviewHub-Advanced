@model BookReviewHub.Helpers.PaginatedList<BookReviewHub.ViewModels.BookViewModel>
@{
    ViewData["Title"] = "Manage Books";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Manage Books</h2>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get">
            <div class="input-group">
                <input type="text" name="search" value="@ViewBag.Search"
                       class="form-control" placeholder="Search books…" />
                <button class="btn btn-dark">Search</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Genre</th>
                    <th>Year</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model)
                {
                    <tr>
                        <td class="fw-semibold">@book.Title</td>
                        <td>@book.AuthorName</td>
                        <td>@book.GenreName</td>
                        <td>@book.PublicationYear</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@book.Id"
                               class="btn btn-outline-secondary btn-sm">Edit</a>
                            <form asp-action="Delete" asp-route-id="@book.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this book?')">
                                <button class="btn btn-outline-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>